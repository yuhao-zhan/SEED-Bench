+import re
+from stages import _LAUNCH_KEYS, _VEL_KEYS, _fmt_time_val, _launch_schedule_sentence, _speed_list_sentence
+
+# Mock terrain_config
+tc_base = {}
+tc_tgt = {
+    "second_ball_launch_time": 0.26,
+    "third_ball_launch_time": 0.58,
+    "fourth_ball_launch_time": 0.88,
+    "fifth_ball_launch_time": 1.18,
+    "sixth_ball_launch_time": 1.48,
+    "seventh_ball_launch_time": 1.78,
+    "ball_velocity_x": -36.0,
+    "ball2_velocity_x": -38.0,
+    "ball3_velocity_x": -36.0,
+    "ball4_velocity_x": -40.0,
+    "ball5_velocity_x": -37.0,
+    "ball6_velocity_x": -38.0,
+    "ball7_velocity_x": -37.0,
+}
+
+base_m = {k: dflt for k, dflt in _LAUNCH_KEYS}
+base_m.update({k: dflt for k, dflt in _VEL_KEYS})
+tgt_m = {**base_m, **tc_tgt}
+
+sched_new = _launch_schedule_sentence(tgt_m)
+sched_old = _launch_schedule_sentence(base_m)
+
+print(f"Sched new: {sched_new}")
+print(f"Sched old: {sched_old}")
+
+# Pattern test
+desc = "ball 2 at t=0.4 s, ball 3 at t=1.0 s, ball 4 at t=1.3 s, ball 5 at t=1.8 s, ball 6 at t=2.2 s, ball 7 at t=2.7 s."
+sched_pat = (
+    r"(receive horizontal velocity at the listed times \(simulation time in seconds after reset\): )"
+    r"(ball 2 at t=[\d.]+ s, ball 3 at t=[\d.]+ s, ball 4 at t=[\d.]+ s, ball 5 at t=[\d.]+ s, "
+    r"ball 6 at t=[\d.]+ s, ball 7 at t=[\d.]+ s)(\.)"
+)
+match = re.search(sched_pat, "receive horizontal velocity at the listed times (simulation time in seconds after reset): " + desc)
+print(f"Match found: {bool(match)}")
+
+# Speed list test
+spd_new = _speed_list_sentence(tgt_m)
+spd_old = _speed_list_sentence(base_m)
+print(f"Speed new: {spd_new}")
+print(f"Speed old: {spd_old}")
+
+spd_pat = (
+    r"(Nominal horizontal speeds at release \(m/s\) are )"
+    r"(ball1=-?\d+(?:\.\d+)?, ball2=-?\d+(?:\.\d+)?, ball3=-?\d+(?:\.\d+)?, "
+    r"ball4=-?\d+(?:\.\d+)?, ball5=-?\d+(?:\.\d+)?, ball6=-?\d+(?:\.\d+)?, "
+    r"ball7=-?\d+(?:\.\d+)?)(\.)"
+)
+desc_spd = "Nominal horizontal speeds at release (m/s) are ball1=-24, ball2=-26, ball3=-24, ball4=-28, ball5=-25, ball6=-26, ball7=-25."
+match_spd = re.search(spd_pat, desc_spd)
+print(f"Match speed found: {bool(match_spd)}")
